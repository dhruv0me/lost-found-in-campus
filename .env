# AICE Campus Lost & Found Portal — Environment Variables

# Server
PORT=3000

# Gmail SMTP for email notifications
# 1. Enable 2-Step Verification on your Gmail: https://myaccount.google.com/security
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Paste your Gmail address and the generated App Password below

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# Base URL (used in email links)
BASE_URL=http://localhost:3000
